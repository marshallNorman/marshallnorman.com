---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Carousel from '../../components/Carousel.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
const heroSvg = readFileSync(join(process.cwd(), 'public/images/hero-illustration.svg'), 'utf-8');
---

<Layout>
  <div class="cs-topo-bg" aria-hidden="true"></div>
  <Nav activeHref="#case-studies" anchorLinks={[
    { label: "Overview", href: "#overview" },
    { label: "Context", href: "#context" },
    { label: "0→1", href: "#zero-to-one" },
    { label: "Scaling", href: "#scaling" },
    { label: "Design Thinking", href: "#design-thinking" },
    { label: "Outcomes", href: "#outcomes" },
  ]} />

  <!-- Hero is OUTSIDE cs-page so overflow-x:clip doesn't clip the full-bleed illustration -->
  <section id="overview" class="cs-hero">

    <!-- Staggered headline — matches Figma layout -->
    <div class="hero-text-area">
      <div class="hero-headline">
        <h1 class="cs-title">Designing an <em class="cs-title-accent">Agentic AI</em> Platform<br/>from the Ground Up</h1>
      </div>
      <div class="hero-subhead">
        <div class="hero-divider" aria-hidden="true"></div>
        <p class="cs-subtitle">From undefined concept to scalable enterprise platform — leading design solo through launch, then steering a team of eight through a full platform expansion.</p>
      </div>
    </div>

    <!-- Full-bleed animated illustration (inlined SVG for JS animation control) -->
    <div class="hero-illustration">
      <Fragment set:html={heroSvg} />
    </div>

  </section>

  <div class="cs-page">
    <!-- 01 — Context -->
    <section id="context" class="cs-section">
      <p class="section-label">Section 01 — Context</p>
      <div class="cs-section-grid">
        <div>
          <h2 class="cs-heading">A new kind of product in a familiar space</h2>
        </div>
        <div>
          <p class="cs-intro">In 2024, Dialpad bet on agentic AI — not assistive features, but truly autonomous voice and chat agents capable of taking action across enterprise systems. The concept of an AI agent inside a real-time communications platform was largely undefined. No pattern existed to borrow from. The business need was clear; the design problem was not.</p>
          <p class="cs-intro">I was brought in as the only designer on a 50-person cross-functional task force to figure it out.</p>
        </div>
      </div>

      <!-- Context schematic: contact center routing flow with AI Agents as new autonomous path -->
      <div style="margin-top: 64px;">
        <svg class="cs-fig" viewBox="0 0 800 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="800" height="320" fill="#f1ede6"/>

          <!-- Contact center zone (dashed outline) -->
          <rect x="212" y="24" width="556" height="264" rx="6" fill="none" stroke="#000" stroke-width="1" stroke-dasharray="4 6" opacity="0.12"/>
          <text x="226" y="42" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.2" letter-spacing="0.1em">CONTACT CENTER</text>

          <!-- Customer channels (left, outside CC zone) -->
          <text x="102" y="34" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.2" text-anchor="middle" letter-spacing="0.1em">CUSTOMERS</text>
          <rect x="32" y="60" width="140" height="34" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.28"/>
          <text x="102" y="81" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.5" text-anchor="middle">Voice</text>
          <rect x="32" y="118" width="140" height="34" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.28"/>
          <text x="102" y="139" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.5" text-anchor="middle">Chat</text>
          <rect x="32" y="176" width="140" height="34" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.28"/>
          <text x="102" y="197" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.5" text-anchor="middle">Digital</text>

          <!-- Lines converging from channels → IVR -->
          <line x1="172" y1="77" x2="248" y2="156" stroke="#000" stroke-width="1" opacity="0.12"/>
          <line x1="172" y1="135" x2="248" y2="156" stroke="#000" stroke-width="1" opacity="0.12"/>
          <line x1="172" y1="193" x2="248" y2="156" stroke="#000" stroke-width="1" opacity="0.12"/>

          <!-- IVR / Routing node -->
          <rect x="248" y="132" width="116" height="48" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.35"/>
          <text x="306" y="153" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.55" text-anchor="middle">IVR /</text>
          <text x="306" y="169" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.55" text-anchor="middle">Routing</text>

          <!-- Branch lines from IVR right edge -->
          <line x1="364" y1="148" x2="436" y2="90" stroke="#000" stroke-width="1" opacity="0.14"/>
          <line x1="364" y1="164" x2="436" y2="228" stroke="#000" stroke-width="1" opacity="0.14"/>

          <!-- Human Agents node (established, solid) -->
          <rect x="436" y="68" width="124" height="44" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.35"/>
          <text x="498" y="94" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.55" text-anchor="middle">Human Agents</text>

          <!-- Supporting Dialpad tools beside Human Agents (bracket) -->
          <line x1="560" y1="90" x2="576" y2="90" stroke="#000" stroke-width="1" opacity="0.12"/>
          <line x1="576" y1="68" x2="576" y2="136" stroke="#000" stroke-width="1" opacity="0.1"/>
          <text x="584" y="77" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.35">AI Coaching</text>
          <text x="584" y="93" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.35">Ai CSAT</text>
          <text x="584" y="109" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.35">AI Playbooks</text>
          <text x="584" y="125" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.35">Integrations</text>

          <!-- AI AGENT? node (dashed — new, undefined) -->
          <rect x="436" y="206" width="124" height="52" rx="4" fill="none" stroke="#000" stroke-width="1" stroke-dasharray="3 4" opacity="0.38"/>
          <text x="498" y="229" font-family="IBM Plex Mono, monospace" font-size="11" fill="#000" opacity="0.45" text-anchor="middle" letter-spacing="0.04em">AI AGENT?</text>
          <text x="498" y="246" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.25" text-anchor="middle">undefined</text>

          <!-- NEW badge floating above AI AGENT? rect -->
          <rect x="516" y="198" width="36" height="16" rx="3" fill="#000" opacity="0.55"/>
          <text x="534" y="209" font-family="IBM Plex Mono, monospace" font-size="8" fill="#fff" opacity="0.9" text-anchor="middle" letter-spacing="0.08em">NEW</text>

          <!-- Fig label -->
          <text x="40" y="304" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.25" letter-spacing="0.06em">FIG. 01 — CONTACT CENTER CONTEXT / AUTONOMOUS PATH UNDEFINED</text>
        </svg>
        <p class="cs-fig-caption">Fig. 01 — AI Agents entered a contact center with established routing, tooling, and human workflows already in place. The autonomous path was entirely new — and entirely undefined.</p>
      </div>
    </section>

    <!-- 02 — 0→1 -->
    <section id="zero-to-one" class="cs-section">
      <p class="section-label">Section 02 — 0 → 1</p>
      <h2 class="cs-heading">Defining what an agent actually is</h2>

      <div class="cs-prose" style="margin-top: 40px; max-width: 800px;">
        <p>Before any interface could be designed, we had to answer a harder question: what does it mean for software to act autonomously on behalf of a human — and how do we keep that human meaningfully in control?</p>
        <p>I worked across product and engineering to define the agent's behavioral model: how it reasons, when it acts, when it defers, and how it fails gracefully. I designed the creation and management system — the workflows admins use to configure agents, define skills, attach knowledge sources, and set behavioral constraints. I also established the safety and guardrail patterns that formed the product's trust layer, making agent behavior legible and interruptible.</p>
      </div>

      <!-- Fig. 02: Agent Component Model -->
      <div style="margin-top: 48px;">
        <svg class="cs-fig" viewBox="0 0 800 360" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="800" height="360" fill="#f1ede6"/>
          <!-- Spokes — solid, defined -->
          <line x1="400" y1="150" x2="400" y2="88" stroke="#000" stroke-width="1" opacity="0.18"/>
          <line x1="400" y1="210" x2="400" y2="272" stroke="#000" stroke-width="1" opacity="0.18"/>
          <line x1="355" y1="180" x2="232" y2="180" stroke="#000" stroke-width="1" opacity="0.18"/>
          <line x1="445" y1="180" x2="568" y2="180" stroke="#000" stroke-width="1" opacity="0.18"/>
          <!-- Center node: AI AGENT (defined now) -->
          <rect x="355" y="150" width="90" height="60" rx="6" fill="none" stroke="#000" stroke-width="1.5" opacity="0.5"/>
          <text x="400" y="178" font-family="IBM Plex Mono, monospace" font-size="11" fill="#000" opacity="0.7" text-anchor="middle" letter-spacing="0.04em">AI AGENT</text>
          <text x="400" y="195" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.3" text-anchor="middle">defined</text>
          <!-- Node: Knowledge Base (top) -->
          <rect x="328" y="44" width="144" height="44" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.35"/>
          <text x="400" y="63" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.6" text-anchor="middle">Knowledge Base</text>
          <text x="400" y="78" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.28" text-anchor="middle">documents + data sources</text>
          <!-- Node: Skills (left) -->
          <rect x="100" y="156" width="132" height="48" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.35"/>
          <text x="166" y="177" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.6" text-anchor="middle">Skills</text>
          <text x="166" y="193" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.28" text-anchor="middle">actions the agent can take</text>
          <!-- Node: MCP Server (right) -->
          <rect x="568" y="156" width="132" height="48" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.35"/>
          <text x="634" y="177" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.6" text-anchor="middle">MCP Server</text>
          <text x="634" y="193" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.28" text-anchor="middle">tool + API connections</text>
          <!-- Node: Deterministic Workflows (bottom) -->
          <rect x="296" y="272" width="208" height="44" rx="4" fill="none" stroke="#000" stroke-width="1" opacity="0.35"/>
          <text x="400" y="291" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" opacity="0.6" text-anchor="middle">Deterministic Workflows</text>
          <text x="400" y="306" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.28" text-anchor="middle">structured decision paths</text>
          <!-- Label -->
          <text x="40" y="340" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.25" letter-spacing="0.06em">FIG. 02 — AGENT COMPONENT MODEL</text>
        </svg>
        <p class="cs-fig-caption">Fig. 02 — The agent's own architecture: four building blocks distinct from Dialpad's existing platform capabilities.</p>
      </div>

      <div class="cs-pull-quote">
        <blockquote>"The hardest design problems weren't visual. They were behavioral — determining how much autonomy was appropriate, and how to make that visible."</blockquote>
      </div>

      <div style="margin-top: 48px;">
        <!-- desktop: full animated 5-panel SVG -->
        <div class="hidden md:block">
        <svg id="fig03" class="cs-fig" viewBox="0 0 960 520" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <style>
              /* base: element fade-up, arrow fade */
              #fig03 .e  {opacity:0;animation:f3up .30s ease-out forwards;animation-play-state:paused}
              #fig03 .arr{opacity:0;animation:f3fd .20s ease-out forwards;animation-play-state:paused}
              /* panel 1 — base 0s, stagger 0.08s, last el at 0.56s */
              #fig03 .e1a{animation-delay:0s}    #fig03 .e1b{animation-delay:.08s}
              #fig03 .e1c{animation-delay:.16s}  #fig03 .e1d{animation-delay:.24s}
              #fig03 .e1e{animation-delay:.32s}  #fig03 .e1f{animation-delay:.40s}
              #fig03 .e1g{animation-delay:.48s}  #fig03 .e1h{animation-delay:.56s}
              /* panel 2 — base 0.82s (0.56 + 85%×0.30 = 0.815 ≈ 0.82) */
              #fig03 .e2a{animation-delay:.82s}  #fig03 .e2b{animation-delay:.90s}
              #fig03 .e2c{animation-delay:.98s}  #fig03 .e2d{animation-delay:1.06s}
              #fig03 .e2e{animation-delay:1.14s} #fig03 .e2f{animation-delay:1.22s}
              #fig03 .e2g{animation-delay:1.30s} #fig03 .e2h{animation-delay:1.38s}
              /* panel 3 — base 1.64s */
              #fig03 .e3a{animation-delay:1.64s} #fig03 .e3b{animation-delay:1.72s}
              #fig03 .e3c{animation-delay:1.80s} #fig03 .e3d{animation-delay:1.88s}
              #fig03 .e3e{animation-delay:1.96s} #fig03 .e3f{animation-delay:2.04s}
              #fig03 .e3g{animation-delay:2.12s} #fig03 .e3h{animation-delay:2.20s}
              /* panel 4 — base 2.46s */
              #fig03 .e4a{animation-delay:2.46s} #fig03 .e4b{animation-delay:2.54s}
              #fig03 .e4c{animation-delay:2.62s} #fig03 .e4d{animation-delay:2.70s}
              #fig03 .e4e{animation-delay:2.78s} #fig03 .e4f{animation-delay:2.86s}
              #fig03 .e4g{animation-delay:2.94s} #fig03 .e4h{animation-delay:3.02s}
              /* panel 5 — base 3.28s */
              #fig03 .e5a{animation-delay:3.28s} #fig03 .e5b{animation-delay:3.36s}
              #fig03 .e5c{animation-delay:3.44s} #fig03 .e5d{animation-delay:3.52s}
              #fig03 .e5e{animation-delay:3.60s} #fig03 .e5f{animation-delay:3.68s}
              #fig03 .e5g{animation-delay:3.76s} #fig03 .e5h{animation-delay:3.84s}
              /* arrows fire with next panel's first element */
              #fig03 .a12{animation-delay:.82s}  #fig03 .a23{animation-delay:1.64s}
              #fig03 .a34{animation-delay:2.46s} #fig03 .a45{animation-delay:3.28s}
              /* trigger */
              #fig03.anim-ready .e,#fig03.anim-ready .arr{animation-play-state:running}
              @keyframes f3up{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
              @keyframes f3fd{from{opacity:0}to{opacity:.25}}
            </style>
          </defs>

          <rect width="960" height="520" fill="#f1ede6"/>

          <!-- ─── Panel 1: DEFINE ─── -->
          <g class="e e1a"><!-- shell -->
            <text x="110" y="34" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.50" text-anchor="middle" letter-spacing="0.08em">DEFINE</text>
            <rect x="24" y="44" width="172" height="420" rx="6" fill="#fff" stroke="#000" stroke-width="1" opacity="0.10"/>
            <text x="32" y="60" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.45">01</text>
          </g>
          <g class="e e1b"><!-- agent name -->
            <text x="36" y="72" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Agent name</text>
            <rect x="36" y="76" width="148" height="20" rx="3" fill="#faf8f4" stroke="#000" stroke-width="0.75" opacity="0.12"/>
          </g>
          <g class="e e1c"><!-- company name -->
            <text x="36" y="110" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Company name</text>
            <rect x="36" y="114" width="148" height="20" rx="3" fill="#faf8f4" stroke="#000" stroke-width="0.75" opacity="0.12"/>
          </g>
          <g class="e e1d"><!-- describe company -->
            <text x="36" y="148" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Describe your company</text>
            <rect x="36" y="152" width="148" height="52" rx="3" fill="#faf8f4" stroke="#000" stroke-width="0.75" opacity="0.12"/>
            <rect x="44" y="162" width="115" height="3" rx="1.5" fill="#F2ECE5"/>
            <rect x="44" y="170" width="90"  height="3" rx="1.5" fill="#F2ECE5"/>
            <rect x="44" y="178" width="75"  height="3" rx="1.5" fill="#F2ECE5"/>
          </g>
          <g class="e e1e"><!-- describe tasks -->
            <text x="36" y="220" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Describe your tasks</text>
            <rect x="36" y="224" width="148" height="52" rx="3" fill="#faf8f4" stroke="#000" stroke-width="0.75" opacity="0.12"/>
            <rect x="44" y="234" width="100" height="3" rx="1.5" fill="#F2ECE5"/>
            <rect x="44" y="242" width="125" height="3" rx="1.5" fill="#F2ECE5"/>
            <rect x="44" y="250" width="60"  height="3" rx="1.5" fill="#F2ECE5"/>
          </g>
          <g class="e e1f"><!-- voice & tone -->
            <text x="36" y="292" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Voice &amp; tone</text>
            <rect x="36" y="296" width="148" height="20" rx="3" fill="#faf8f4" stroke="#000" stroke-width="0.75" opacity="0.12"/>
            <text x="178" y="310" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.45" text-anchor="end">&#8964;</text>
          </g>
          <g class="e e1g"><!-- language -->
            <text x="36" y="332" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Language</text>
            <rect x="36" y="336" width="148" height="20" rx="3" fill="#faf8f4" stroke="#000" stroke-width="0.75" opacity="0.12"/>
            <text x="178" y="350" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.45" text-anchor="end">&#8964;</text>
          </g>
          <g class="e e1h"><!-- create button -->
            <rect x="36" y="404" width="148" height="28" rx="4" fill="#111"/>
            <text x="110" y="421" font-family="IBM Plex Mono, monospace" font-size="7" fill="#fff" opacity="0.70" text-anchor="middle" letter-spacing="0.04em">Create agent</text>
          </g>

          <text class="arr a12" x="202" y="259" font-family="IBM Plex Mono, monospace" font-size="10" fill="#000" text-anchor="middle">&#8594;</text>

          <!-- ─── Panel 2: KNOWLEDGE ─── -->
          <g class="e e2a"><!-- shell + header -->
            <text x="294" y="34" font-family="IBM Plex Mono, monospace" font-size="9" fill="#000" opacity="0.50" text-anchor="middle" letter-spacing="0.08em">KNOWLEDGE</text>
            <rect x="208" y="44" width="172" height="420" rx="6" fill="#fff" stroke="#000" stroke-width="1" opacity="0.10"/>
            <text x="216" y="60" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.45">02</text>
            <text x="220" y="72" font-family="IBM Plex Mono, monospace" font-size="8" fill="#000" opacity="0.55" letter-spacing="0.03em">Knowledge sources</text>
            <line x1="220" y1="80" x2="368" y2="80" stroke="#e8e3db" stroke-width="1"/>
          </g>
          <g class="e e2b"><!-- Zendesk -->
            <rect x="220" y="89" width="14" height="14" rx="2" fill="#f0ece4"/>
            <text x="240" y="98" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Zendesk</text>
            <circle cx="364" cy="96" r="4" fill="#111" opacity="0.55"/>
            <line x1="220" y1="111" x2="368" y2="111" stroke="#e8e3db" stroke-width="0.5" opacity="0.6"/>
          </g>
          <g class="e e2c"><!-- Google Drive -->
            <rect x="220" y="119" width="14" height="14" rx="2" fill="#f0ece4"/>
            <text x="240" y="128" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Google Drive</text>
            <circle cx="364" cy="126" r="4" fill="#111" opacity="0.55"/>
            <line x1="220" y1="141" x2="368" y2="141" stroke="#e8e3db" stroke-width="0.5" opacity="0.6"/>
          </g>
          <g class="e e2d"><!-- Document360 -->
            <rect x="220" y="149" width="14" height="14" rx="2" fill="#f0ece4"/>
            <text x="240" y="158" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.50">Document360</text>
            <circle cx="364" cy="156" r="4" fill="#111" opacity="0.55"/>
            <line x1="220" y1="171" x2="368" y2="171" stroke="#e8e3db" stroke-width="0.5" opacity="0.6"/>
          </g>
          <g class="e e2e"><!-- Webcrawler -->
            <rect x="220" y="179" width="14" height="14" rx="2" fill="#f5f1eb"/>
            <text x="240" y="188" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.45">Webcrawler</text>
            <circle cx="364" cy="186" r="4" fill="#111" opacity="0.18"/>
            <line x1="220" y1="202" x2="368" y2="202" stroke="#e8e3db" stroke-width="1"/>
          </g>
          <g class="e e2f"><!-- configure sources -->
            <rect x="220" y="210" width="148" height="24" rx="3" fill="none" stroke="#000" stroke-width="1" opacity="0.22"/>
            <text x="294" y="225" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.55" text-anchor="middle">Configure sources</text>
            <line x1="220" y1="246" x2="368" y2="246" stroke="#e8e3db" stroke-width="1"/>
          </g>
          <g class="e e2g"><!-- add document -->
            <rect x="220" y="254" width="148" height="24" rx="3" fill="none" stroke="#000" stroke-width="1" opacity="0.22"/>
            <text x="294" y="269" font-family="IBM Plex Mono, monospace" font-size="7" fill="#000" opacity="0.55" text-anchor="middle">+ Add document</text>
          </g>
          <g class="e e2h"><!-- note bars -->
            <rect x="220" y="296" width="130" height="3" rx="1.5" fill="#e8e3db" opacity="0.55"/>
            <rect x="220" y="305" width="100" height="3" rx="1.5" fill="#e8e3db" opacity="0.55"/>
            <rect x="220" y="314" width="115" height="3" rx="1.5" fill="#e8e3db" opacity="0.40"/>
