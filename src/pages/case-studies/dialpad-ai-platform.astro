<script>
  function placeBreadcrumbs() {
    const page = document.querySelector('.cs-page') as HTMLElement | null;
    if (!page) return;

    // Clear any previously placed breadcrumbs (appended to body)
    document.querySelectorAll('.cs-breadcrumb').forEach(el => el.remove());

    // Offset from top of document so top values are absolute page positions
    const pageTop = page.getBoundingClientRect().top + window.scrollY;
    const totalHeight = page.scrollHeight;
    const start = 600;
    const interval = 1200;

    for (let top = start; top < totalHeight; top += interval) {
      const el = document.createElement('p');
      el.className = 'cs-breadcrumb';
      el.innerHTML = '<a href="/#case-studies" class="cs-breadcrumb-link">Case Studies</a> / Designing Dialpad\'s Agentic AI Platform';
      el.style.top = `${pageTop + top}px`;
      document.body.appendChild(el);
    }
  }

  // Place on load, then again once fonts are ready (they affect page height)
  placeBreadcrumbs();
  document.fonts?.ready.then(placeBreadcrumbs);

  // Trigger hero illustration animations when the illustration's bottom scrolls into view
  function setupAnimTrigger() {
    if (window.innerWidth <= 768) return;
    const svg = document.getElementById('hero-svg');
    const illustration = document.querySelector('.hero-illustration') as HTMLElement | null;
    if (!svg || !illustration) return;

    function check() {
      const bottom = illustration.getBoundingClientRect().bottom;
      if (bottom <= window.innerHeight) {
        svg.classList.add('anim-ready');
        window.removeEventListener('scroll', check);
      }
    }
    window.addEventListener('scroll', check, { passive: true });
  }
  setupAnimTrigger();
</script>


