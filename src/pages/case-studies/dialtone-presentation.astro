---
import '../../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, viewport-fit=cover" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
  <title>Rebuilding Dialtone — Case Study</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Serif:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── Password Gate ─────────────────────────────────────────── -->
  <div id="gate" class="gate">
    <div class="gate-card">
      <p class="gate-label">Dialtone Case Study · Restricted Access</p>
      <h1 class="gate-title">Enter password<br/>to continue</h1>
      <div class="gate-input-row">
        <input
          id="gate-input"
          type="password"
          class="gate-input"
          placeholder="password"
          autocomplete="off"
          autocapitalize="none"
          spellcheck="false"
        />
        <button id="gate-btn" class="gate-btn" aria-label="Submit">→</button>
      </div>
      <p id="gate-error" class="gate-error" aria-live="polite"></p>
    </div>
  </div>

  <!-- ── Presentation ──────────────────────────────────────────── -->
  <div id="preso" class="preso" style="display:none; opacity:0;">

    <div id="track" class="track">

      <!-- ── Slide 01 · Cover ───────────────────────────────────── -->
      <div class="slide slide-cover">
        <div class="slide-inner">
          <div class="cover-content">
            <p class="cover-label">Dialpad · 2022–2023</p>
            <h1 class="cover-title">Rebuilding<br/>Dialtone</h1>
            <p class="cover-sub">v5 → v7 → v9</p>
            <div class="cover-divider"></div>
            <div class="cover-tags">
              <span class="cover-tag">Lead Designer</span>
              <span class="cover-tag">Design Systems</span>
              <span class="cover-tag">Typography · Color · Scale</span>
            </div>
            <p class="cover-byline">Marshall Norman · Staff Product Designer · Dialpad</p>
          </div>
          <p class="nav-hint">← → to navigate</p>
        </div>
      </div>

      <!-- ── Slide 02 · Context ─────────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">01 / Context</p>
          <h2 class="slide-heading">A design system built<br/>to scale a company.</h2>
          <div class="slide-body">
            <p class="slide-prose">Dialpad is a cloud communications platform — voice, video, messaging, and AI — used by hundreds of thousands of businesses. Dialtone is the design system that powers every surface across every product. At the scale Dialpad was operating, inconsistency wasn't a polish problem. It was a velocity problem. A coherence problem. A trust problem.</p>
            <blockquote class="pull-quote">
              "Design systems don't just make products look consistent — they determine how fast a team can move without breaking what they've already built."
            </blockquote>
          </div>
        </div>
      </div>

      <!-- ── Slide 03 · The Problem ─────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">02 / The Problem</p>
          <h2 class="slide-heading">What v5 couldn't do.</h2>
          <div class="problem-grid">
            <div class="problem-card">
              <p class="problem-card-num">01</p>
              <p class="problem-card-title">Naming ambiguity</p>
              <p class="problem-card-body">T-shirt sizing — sm, md, lg — carried no semantic meaning. Designers couldn't derive intent from a token name. Every decision required looking it up.</p>
            </div>
            <div class="problem-card">
              <p class="problem-card-num">02</p>
              <p class="problem-card-title">No token layer</p>
              <p class="problem-card-body">Colors and spacing were hardcoded values, not tokens. Multi-theme support — T-Mobile, dark mode, expressive themes — was a manual, error-prone process.</p>
            </div>
            <div class="problem-card">
              <p class="problem-card-num">03</p>
              <p class="problem-card-title">Contribution gap</p>
              <p class="problem-card-body">No clear path for product teams to contribute back. The system grew stale as product shipped. Designers worked around it instead of through it.</p>
            </div>
          </div>
          <blockquote class="pull-quote pull-quote--inline">
            "The cost of inconsistency compounds. Every workaround is debt the next designer inherits."
          </blockquote>
        </div>
      </div>

      <!-- ── Slide 04 · The Vision ──────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">03 / Vision</p>
          <h2 class="slide-heading">What we needed<br/>Dialtone to become.</h2>
          <div class="vision-grid">
            <div class="vision-card vision-card--accent">
              <p class="vision-card-label">Systematic</p>
              <p class="vision-card-body">Every decision derivable from a token, not a file. Typography, color, spacing — all living in a structured hierarchy that designers and engineers shared.</p>
            </div>
            <div class="vision-card">
              <p class="vision-card-label">Accessible by default</p>
              <p class="vision-card-body">WCAG AA/AAA compliance baked into the token layer — not retrofitted. Every color pair, every type size validated before it ships.</p>
            </div>
            <div class="vision-card">
              <p class="vision-card-label">Contributable</p>
              <p class="vision-card-body">A system designers and engineers could participate in. Clear rules for what gets in, how, and why — so the system evolves with the product.</p>
            </div>
          </div>
          <p class="slide-footnote">These three principles guided every decision in v7.</p>
        </div>
      </div>

      <!-- ── Slide 05 · My Role ─────────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">04 / My Role</p>
          <h2 class="slide-heading">How I led this.</h2>
          <div class="role-grid">
            <div class="role-card">
              <p class="role-card-label">Design Lead</p>
              <p class="role-card-title">Typography · Color · Scale</p>
              <p class="role-card-body">Owned the foundational decisions end-to-end — naming conventions, token hierarchy, spacing system. From first principles to shipped implementation.</p>
            </div>
            <div class="role-card">
              <p class="role-card-label">System Architect</p>
              <p class="role-card-title">Token structure · Naming · Themes</p>
              <p class="role-card-body">Defined how the token layer was organized — semantic naming, multi-theme architecture, the relationship between primitive and semantic tokens.</p>
            </div>
            <div class="role-card">
              <p class="role-card-label">Enablement</p>
              <p class="role-card-title">Tooling · Contribution · Process</p>
              <p class="role-card-body">Built tooling for the design team. Defined the contribution model — what gets in, what doesn't, and the process that made it sustainable.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Slide 06 · Typography ──────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">05 / Typography</p>
          <h2 class="slide-heading">A type scale built<br/>on explicit semantics.</h2>
          <div class="type-slide-body">
            <div class="type-scale-visual" aria-hidden="true">
              <div class="type-row">
                <span class="type-size-label">32</span>
                <span class="type-sample" style="font-size:32px; line-height:40px;">Communicate clearly.</span>
              </div>
              <div class="type-row">
                <span class="type-size-label">24</span>
                <span class="type-sample" style="font-size:24px; line-height:32px;">Design at scale.</span>
              </div>
              <div class="type-row">
                <span class="type-size-label">20</span>
                <span class="type-sample" style="font-size:20px; line-height:28px;">Consistent across products.</span>
              </div>
              <div class="type-row">
                <span class="type-size-label">16</span>
                <span class="type-sample" style="font-size:16px; line-height:24px;">Every token has a purpose.</span>
              </div>
              <div class="type-row">
                <span class="type-size-label">14</span>
                <span class="type-sample" style="font-size:14px; line-height:20px;">Accessible by default, not by accident.</span>
              </div>
              <div class="type-row">
                <span class="type-size-label">12</span>
                <span class="type-sample" style="font-size:12px; line-height:16px;">Supporting text, labels, and metadata.</span>
              </div>
              <div class="type-row">
                <span class="type-size-label">11</span>
                <span class="type-sample" style="font-size:11px; line-height:16px; opacity:0.6;">Captions, timestamps, secondary information.</span>
              </div>
            </div>
            <div class="type-decisions">
              <div class="type-decision">
                <p class="type-decision-label">Naming</p>
                <p class="type-decision-body">Shifted from t-shirt sizing (sm/md/lg) to explicit numeric naming at v5.8.0. `dt-font-size-200` tells you the size. `dt-font-size-md` does not.</p>
              </div>
              <div class="type-decision">
                <p class="type-decision-label">Line-height</p>
                <p class="type-decision-body">All line-heights strictly adhere to 4px increments. Baseline grids stay predictable across every component, every platform.</p>
              </div>
              <div class="type-decision">
                <p class="type-decision-label">Fluid scaling</p>
                <p class="type-decision-body">Token values pair with `clamp()` in implementation — responsive by default, no breakpoint overrides needed for type size.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Slide 07 · Color ───────────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">06 / Color</p>
          <h2 class="slide-heading">Tokens, themes, and<br/>the accessibility floor.</h2>
          <div class="color-slide-body">
            <div class="color-prose-col">
              <p class="slide-prose">The v7 color system moved from hardcoded hex values to a two-layer token architecture: primitive tokens (the raw palette) and semantic tokens (what those colors mean in context). This made multi-theme support — Dialpad Light, Dialpad Dark, T-Mobile, Expressive — a configuration, not a rewrite.</p>
              <div class="wcag-callout">
                <span class="wcag-badge">WCAG 2.1 AAA</span>
                <p class="wcag-text">All Dialtone colors meet Level AAA contrast ratio (≥ 7:1). The accessibility floor is part of the token definition, not a post-hoc audit.</p>
              </div>
            </div>
            <div class="color-swatches">
              <div class="color-category">
                <div class="swatch-row">
                  <span class="swatch" style="background:#6c3dff;"></span>
                  <span class="swatch" style="background:#8B5FFF;"></span>
                  <span class="swatch" style="background:#D4BCFF;"></span>
                  <span class="swatch" style="background:#f5f2ff;"></span>
                </div>
                <p class="swatch-label">Brand / Interactive</p>
              </div>
              <div class="color-category">
                <div class="swatch-row">
                  <span class="swatch" style="background:#10022C;"></span>
                  <span class="swatch" style="background:#2D1B5A;"></span>
                  <span class="swatch" style="background:#6B6B7B;"></span>
                  <span class="swatch" style="background:#C8C8D4;"></span>
                </div>
                <p class="swatch-label">Neutral</p>
              </div>
              <div class="color-category">
                <div class="swatch-row">
                  <span class="swatch" style="background:#0A7C42;"></span>
                  <span class="swatch" style="background:#B8470A;"></span>
                  <span class="swatch" style="background:#C41F1F;"></span>
                  <span class="swatch" style="background:#0057B8;"></span>
                </div>
                <p class="swatch-label">Semantic (success · warning · error · info)</p>
              </div>
              <div class="color-category">
                <div class="swatch-row">
                  <span class="swatch swatch--theme" style="background:#6c3dff;" title="Dialpad"></span>
                  <span class="swatch swatch--theme" style="background:#E20074;" title="T-Mobile"></span>
                  <span class="swatch swatch--theme" style="background:#1A1A2E;" title="Dark"></span>
                  <span class="swatch swatch--theme" style="background:#FF6B35;" title="Expressive"></span>
                </div>
                <p class="swatch-label">Multi-theme support</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Slide 08 · Scale & Space ───────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">07 / Scale &amp; Space</p>
          <h2 class="slide-heading">Everything on a 4px grid.</h2>
          <div class="scale-slide-body">
            <div class="spacing-ruler" aria-label="Spacing scale visual">
              <div class="spacing-item">
                <div class="spacing-block" style="width:4px; height:4px;"></div>
                <span class="spacing-val">4</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:8px; height:8px;"></div>
                <span class="spacing-val">8</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:12px; height:12px;"></div>
                <span class="spacing-val">12</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:16px; height:16px;"></div>
                <span class="spacing-val">16</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:20px; height:20px;"></div>
                <span class="spacing-val">20</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:24px; height:24px;"></div>
                <span class="spacing-val">24</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:32px; height:32px;"></div>
                <span class="spacing-val">32</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:40px; height:40px;"></div>
                <span class="spacing-val">40</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:48px; height:48px;"></div>
                <span class="spacing-val">48</span>
              </div>
              <div class="spacing-item">
                <div class="spacing-block" style="width:64px; height:64px;"></div>
                <span class="spacing-val">64</span>
              </div>
            </div>
            <div class="scale-decisions">
              <div class="scale-decision">
                <p class="scale-decision-label">Base unit: 4px</p>
                <p class="scale-decision-body">Every spacing value in the system is a multiple of 4. Padding, margin, gap, border-radius — all derivable, all predictable.</p>
              </div>
              <div class="scale-decision">
                <p class="scale-decision-label">Half-steps where needed</p>
                <p class="scale-decision-body">2px half-steps are available for fine-grained control — icon padding, tight list spacing — without breaking the rhythm.</p>
              </div>
              <div class="scale-decision">
                <p class="scale-decision-label">Line-height alignment</p>
                <p class="scale-decision-body">Typography line-heights follow the same 4px increment rule. Text and layout share a baseline grid — components snap without hacks.</p>
              </div>
            </div>
          </div>
          <p class="slide-footnote">Predictable rhythm across 200+ components.</p>
        </div>
      </div>

      <!-- ── Slide 09 · Designer Enablement ────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">08 / Enablement</p>
          <h2 class="slide-heading">Making Dialtone a system<br/>you could contribute to.</h2>
          <div class="studio-grid">
            <div class="studio-item">
              <div class="studio-num">01</div>
              <div>
                <p class="studio-title">Icon sizing tool</p>
                <p class="studio-body">A Figma component built for the design team — lets designers output icons at multiple standardized sizes without manual resizing or guessing. One source, all variants.</p>
              </div>
            </div>
            <div class="studio-item">
              <div class="studio-num">02</div>
              <div>
                <p class="studio-title">Contribution types</p>
                <p class="studio-body">Three categories: Fix (defect or docs), Enhancement (extends existing patterns), New Feature (adds net-new components). Single-use elements not accepted — Dialtone is shared infrastructure.</p>
              </div>
            </div>
            <div class="studio-item">
              <div class="studio-num">03</div>
              <div>
                <p class="studio-title">Review process</p>
                <p class="studio-body">#dialtone channel discussion before work starts. Feature branches, conventional commits, squash merges into staging. No surprises at review time.</p>
              </div>
            </div>
            <div class="studio-item">
              <div class="studio-num">04</div>
              <div>
                <p class="studio-title">Quality bar</p>
                <p class="studio-body">Unit tests, Storybook documentation, accessibility compliance, passing linters — all required. The bar isn't high to be gatekeeping. It's high because the system serves everyone.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Slide 10 · Evolution ───────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">09 / Evolution</p>
          <h2 class="slide-heading">The foundation that<br/>made v9 possible.</h2>
          <div class="timeline">
            <div class="timeline-phase">
              <div class="timeline-dot"></div>
              <div class="timeline-line"></div>
              <p class="timeline-period">2021–2022</p>
              <p class="timeline-phase-title">v5</p>
              <p class="timeline-phase-body">T-shirt sizing, hardcoded values, minimal token structure. Component library growing faster than the system could support.</p>
            </div>
            <div class="timeline-phase">
              <div class="timeline-dot timeline-dot--active"></div>
              <div class="timeline-line"></div>
              <p class="timeline-period">2022–2023</p>
              <p class="timeline-phase-title">v7</p>
              <p class="timeline-phase-body">Explicit numeric naming, two-layer token architecture, 4px grid, WCAG AAA compliance, contribution model. The rebuild.</p>
            </div>
            <div class="timeline-phase">
              <div class="timeline-dot"></div>
              <div class="timeline-line"></div>
              <p class="timeline-period">2023–2024</p>
              <p class="timeline-phase-title">v8</p>
              <p class="timeline-phase-body">Monorepo restructure. Vue 3 migration. ESM builds with tree-shaking. The token architecture from v7 made this tractable.</p>
            </div>
            <div class="timeline-phase timeline-phase--last">
              <div class="timeline-dot"></div>
              <p class="timeline-period">2024 → Now</p>
              <p class="timeline-phase-title">v9</p>
              <p class="timeline-phase-body">MCP server integration, AI documentation tooling, deprecated component linting. The system evolving toward AI-native workflows.</p>
            </div>
          </div>
          <blockquote class="pull-quote pull-quote--bottom">
            "The decisions we made in v7 didn't just fix v5. They set the architectural ceiling for everything that came after."
          </blockquote>
        </div>
      </div>

      <!-- ── Slide 11 · Impact ──────────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">10 / Impact</p>
          <h2 class="slide-heading">What it changed.</h2>
          <div class="impact-grid">
            <div class="impact-cell">
              <p class="impact-stat">39</p>
              <p class="impact-label">Components Growing</p>
              <p class="impact-desc">Core primitives showing compounding usage growth in production — dt-button, dt-input, dt-icon leading adoption</p>
            </div>
            <div class="impact-cell">
              <p class="impact-stat">35%</p>
              <p class="impact-label">Token Adoption</p>
              <p class="impact-desc">Of the production codebase now building on Dialtone tokens — up from near zero when the rebuild began</p>
            </div>
            <div class="impact-cell">
              <p class="impact-stat">↓&thinsp;1.9K</p>
              <p class="impact-label">Lint Warnings</p>
              <p class="impact-desc">Active Dialtone ESLint warnings — trending down each period as teams migrate off legacy patterns</p>
            </div>
            <div class="impact-cell">
              <p class="impact-stat">4</p>
              <p class="impact-label">Product Themes</p>
              <p class="impact-desc">Dialpad Light, Dark, T-Mobile, and Expressive — all enabled by the v7 token architecture without per-theme rewrites</p>
            </div>
          </div>
          <p class="slide-footnote">Ubervoice codebase · March 2026 · Dialtone KPIs Dashboard</p>
        </div>
      </div>

      <!-- ── Slide 12 · What's Next ───────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">11 / What's Next</p>
          <h2 class="slide-heading">Dialtone 9.</h2>
          <div class="whats-next-body">
            <p class="slide-prose slide-prose--narrow">The token architecture and contribution model from v7 made Dialtone's next evolution tractable. v9 isn't just more components — it's the system adapting to how teams build AI-native products.</p>
            <div class="whats-next-grid">
              <div class="whats-next-card whats-next-card--featured">
                <p class="whats-next-card-label">AI-Native Tooling</p>
                <p class="whats-next-card-body">MCP server integration and a markdown-to-JSON documentation generator — design system context delivered directly to AI coding environments.</p>
              </div>
              <div class="whats-next-card">
                <p class="whats-next-card-label">Deprecated Component Linting</p>
                <p class="whats-next-card-body">Custom ESLint rule (`deprecated-dialtone-component`) surfaces migration paths at the point of use — automated governance at scale.</p>
              </div>
              <div class="whats-next-card">
                <p class="whats-next-card-label">Rich Text Editor</p>
                <p class="whats-next-card-body">A fully-integrated RTE component built on the system's token layer — powering AI-generated and human-authored content surfaces across Dialpad.</p>
              </div>
              <div class="whats-next-card">
                <p class="whats-next-card-label">Weekly Velocity</p>
                <p class="whats-next-card-body">v9.181.0 shipped April 24, 2026 — the system now releases on a weekly cadence, sustained by the contribution infrastructure built in v7.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Slide 12 · Reflection ──────────────────────────────── -->
      <div class="slide">
        <div class="slide-inner slide-inner--pad">
          <p class="section-label">12 / Reflection</p>
          <h2 class="slide-heading">What this work taught me.</h2>
          <div class="reflection-body">
            <div class="reflection-col">
              <p class="reflection-col-label">What worked</p>
              <ul class="reflection-list">
                <li>Starting with naming — once the token naming convention was right, everything downstream became easier to reason about.</li>
                <li>The contribution model as a forcing function — defining what gets in forced clearer thinking about what the system was actually for.</li>
                <li>Accessibility as a constraint, not a phase — building WCAG compliance into the token layer meant it stopped being a separate workstream.</li>
              </ul>
            </div>
            <div class="reflection-col">
              <p class="reflection-col-label">What I'd do differently</p>
              <ul class="reflection-list">
                <li>Move faster on typography token migration — at 2% adoption, legacy font utilities still dominate. The architecture was right; the migration path needed more forcing functions.</li>
                <li>Instrument adoption earlier — we measured output (tokens shipped, components documented) before we measured outcome (how teams were actually using it). The KPIs dashboard came too late.</li>
              </ul>
            </div>
          </div>
          <p class="reflection-closing">
            "A design system isn't a product. It's infrastructure. The measure of whether it worked is whether the teams who rely on it stopped thinking about it."
          </p>
        </div>
      </div>

    </div><!-- /track -->

    <!-- Nav controls -->
    <button id="btn-prev" class="nav-btn nav-btn--prev" aria-label="Previous slide">‹</button>
    <button id="btn-next" class="nav-btn nav-btn--next" aria-label="Next slide">›</button>

    <!-- Slide counter -->
    <div id="counter" class="slide-counter">1 / 13</div>

  </div><!-- /preso -->

</body>
</html>

<script>
  const TOTAL = 13;
  const PASSWORD = 'dialtonepreso';
  const STORAGE_KEY = 'dialtone-preso-auth';

  let current = 0;

  function showPreso() {
    const gate = document.getElementById('gate')!;
    const preso = document.getElementById('preso')!;
    gate.style.opacity = '0';
    gate.style.pointerEvents = 'none';
    setTimeout(() => { gate.style.display = 'none'; }, 500);
    preso.style.display = 'block';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        preso.style.opacity = '1';
      });
    });
    document.body.style.overflow = 'hidden';
  }

  function shakeCard() {
    const card = document.querySelector('.gate-card') as HTMLElement;
    if (!card) return;
    card.classList.remove('shake');
    void card.offsetWidth;
    card.classList.add('shake');
  }

  function handleAuth() {
    const input = document.getElementById('gate-input') as HTMLInputElement;
    const errorEl = document.getElementById('gate-error')!;
    const val = input.value.trim();
    if (val === PASSWORD) {
      sessionStorage.setItem(STORAGE_KEY, '1');
      errorEl.textContent = '';
      showPreso();
    } else {
      errorEl.textContent = 'Incorrect password.';
      shakeCard();
      input.value = '';
      input.focus();
    }
  }

  function goTo(index: number) {
    if (index < 0 || index >= TOTAL) return;
    current = index;
    const track = document.getElementById('track')!;
    track.style.transform = `translateX(${-current * 100}vw)`;
    const counter = document.getElementById('counter')!;
    counter.textContent = `${current + 1} / ${TOTAL}`;
    const prevBtn = document.getElementById('btn-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('btn-next') as HTMLButtonElement;
    prevBtn.style.opacity = current === 0 ? '0' : '1';
    prevBtn.style.pointerEvents = current === 0 ? 'none' : 'auto';
    nextBtn.style.opacity = current === TOTAL - 1 ? '0' : '1';
    nextBtn.style.pointerEvents = current === TOTAL - 1 ? 'none' : 'auto';
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (sessionStorage.getItem(STORAGE_KEY) === '1') {
      showPreso();
    }

    const btn = document.getElementById('gate-btn')!;
    const input = document.getElementById('gate-input') as HTMLInputElement;
    btn.addEventListener('click', handleAuth);
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') handleAuth();
    });

    document.getElementById('btn-prev')!.addEventListener('click', () => goTo(current - 1));
    document.getElementById('btn-next')!.addEventListener('click', () => goTo(current + 1));

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      const preso = document.getElementById('preso')!;
      if (preso.style.display === 'none' || preso.style.opacity === '0') return;
      if (e.key === 'ArrowRight') goTo(current + 1);
      if (e.key === 'ArrowLeft') goTo(current - 1);
    });

    goTo(0);

    const gate = document.getElementById('gate')!;
    if (gate.style.display !== 'none') {
      (document.getElementById('gate-input') as HTMLInputElement).focus();
    }
  });
</script>

