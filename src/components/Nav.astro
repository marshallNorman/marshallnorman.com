---
interface AnchorLink { label: string; href: string; }
interface Props {
  activeHref?: string;
  anchorLinks?: AnchorLink[];
}
const { activeHref = "#about", anchorLinks } = Astro.props;
const hasAnchors = !!anchorLinks?.length;
---
<div id="site-nav" transition:persist class={hasAnchors ? "has-anchors" : ""}>
  <nav class="nav-main-pill" data-glass>
    <div class="nav-main">
      <a href="#about" class={`nav-link ${activeHref === "#about" ? "active" : ""}`}>About</a>
      <a href="#case-studies" class={`nav-link ${activeHref === "#case-studies" ? "active" : ""}`}>Case Studies</a>
      <a href="#contact" class={`nav-link ${activeHref === "#contact" ? "active" : ""}`}>Contact</a>
    </div>
    {hasAnchors && (
      <a href="/#case-studies" class="nav-back">← Back</a>
    )}
    <div class={`nav-anchors${hasAnchors ? " visible" : ""}`}>
      {anchorLinks?.map(link => (
        <a href={link.href} class="anchor-link">{link.label}</a>
      ))}
    </div>
  </nav>

  {hasAnchors && (
    <div class="nav-sections-pill" data-glass>
      <span class="nav-sections-label">Sections:</span>
      <button class="nav-anchors-toggle" aria-label="Toggle sections" aria-expanded="false">
        Sections
      </button>
      <div class="nav-anchors-popover">
        {anchorLinks?.map(link => (
          <a href={link.href} class="anchor-link">{link.label}</a>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  #site-nav {
    position: fixed;
    top: 16px;
    left: 16px;
    bottom: auto;
    right: auto;
    z-index: 50;
  }

  /* Desktop has-anchors: two pills side by side, same height */
  #site-nav.has-anchors {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }

  .nav-main-pill {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 8px 12px;
    border-radius: 8px;
    white-space: nowrap;
  }

  /* On has-anchors desktop: main pill shows only the back button */
  #site-nav.has-anchors .nav-main-pill {
    display: flex;
    flex-direction: row;
    align-items: center;
  }
  #site-nav.has-anchors .nav-main,
  #site-nav.has-anchors .nav-anchors,
  #site-nav.has-anchors .nav-anchors.visible {
    display: none;
  }

  /* Back button — hidden by default, shown on desktop has-anchors */
  .nav-back {
    display: none;
  }
  #site-nav.has-anchors .nav-back {
    display: flex;
    align-items: center;
    font-family: "IBM Plex Mono", monospace;
    font-size: 16px;
    color: #000;
    opacity: 0.4;
    text-decoration: none;
    white-space: nowrap;
    transition: font-size 0.25s ease;
  }
  #site-nav.scrolled .nav-back {
    font-size: 12px;
  }

  /* Sections pill: hidden by default, shown on desktop has-anchors */
  .nav-sections-pill {
    display: none;
  }
  #site-nav.has-anchors .nav-sections-pill {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 8px;
    gap: 16px;
  }

  /* Toggle button hidden on desktop — links show directly */
  .nav-anchors-toggle {
    display: none;
  }

  /* "Sections:" label — desktop only */
  .nav-sections-label {
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    font-weight: 500;
    color: #000;
    opacity: 0.5;
    white-space: nowrap;
    transition: font-size 0.25s ease;
  }
  #site-nav.scrolled .nav-sections-label {
    font-size: 10px;
  }

  /* Anchor links inline in sections pill on desktop */
  .nav-anchors-popover {
    display: flex;
    flex-direction: row;
    gap: 16px;
  }

  .nav-main {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .nav-anchors {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .nav-anchors.visible {
    opacity: 1;
    margin-top: 6px;
  }

  .nav-link {
    font-family: "IBM Plex Mono", monospace;
    font-size: 16px;
    color: #000;
    opacity: 0.4;
    text-decoration: none;
    line-height: 1;
    transition: font-size 0.25s ease;
  }

  #site-nav.scrolled .nav-link {
    font-size: 12px;
  }

  .nav-link.active {
    text-decoration: underline;
  }

  .anchor-link {
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    color: #000;
    opacity: 0.4;
    text-decoration: none;
    white-space: nowrap;
    line-height: 1;
    transition: font-size 0.25s ease;
  }

  .anchor-link.active {
    text-decoration: underline;
    opacity: 0.4;
  }

  #site-nav.scrolled .anchor-link {
    font-size: 10px;
  }

  @media (max-width: 768px) {
    /* Wrapper spans the bottom of the viewport */
    #site-nav {
      top: auto;
      bottom: 12px;
      left: 12px;
      right: 12px;
      transform: none;
      display: flex;
      align-items: stretch;
      gap: 8px;
    }

    /* Main pill: hug contents by default (anchor pages) */
    .nav-main-pill {
      display: flex;
      flex-direction: row;
      align-items: center;
      flex-shrink: 0;
    }

    /* Home page (no anchors): pill spans full width, links centered */
    #site-nav:not(.has-anchors) .nav-main-pill {
      flex: 1;
    }
    #site-nav:not(.has-anchors) .nav-main {
      flex: 1;
      justify-content: space-around;
      gap: 0;
    }

    /* On anchor pages: hide main links, show back button */
    #site-nav.has-anchors .nav-main {
      display: none;
    }

    /* Back button */
    .nav-back {
      display: none; /* hidden on desktop and non-anchor pages */
    }
    #site-nav.has-anchors .nav-back {
      display: flex;
      align-items: center;
      font-family: "IBM Plex Mono", monospace;
      font-size: 13px;
      color: #000;
      opacity: 0.5;
      text-decoration: none;
      white-space: nowrap;
    }

    /* Hide desktop inline anchor row on mobile */
    .nav-anchors,
    .nav-anchors.visible {
      display: none;
    }

    /* Hide desktop-only label on mobile */
    .nav-sections-label {
      display: none;
    }

    /* Sections pill — fills remaining space, whole pill is tappable */
    .nav-sections-pill {
      display: flex;
      align-items: stretch;
      position: relative;
      flex: 1;
      border-radius: 8px;
      overflow: visible;
      padding: 0;
    }

    /* Toggle button fills the entire pill */
    .nav-anchors-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 8px 12px;
      font-family: "IBM Plex Mono", monospace;
      font-size: 11px;
      opacity: 0.5;
      background: none;
      border: none;
      cursor: pointer;
      color: inherit;
      transition: font-size 0.25s ease, padding 0.25s ease;
    }

    /* Scrolled: shrink back button and sections toggle like home-page nav links */
    #site-nav.scrolled .nav-back {
      font-size: 11px;
    }
    #site-nav.scrolled .nav-anchors-toggle {
      font-size: 9px;
      padding: 6px 10px;
    }

    /* Popover — full width of the sections pill */
    .nav-anchors-popover {
      position: absolute;
      bottom: calc(100% + 8px);
      left: 0;
      right: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      background: rgba(255, 255, 255, 0.55);
      -webkit-backdrop-filter: blur(14px) saturate(180%);
      backdrop-filter: blur(14px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.9), 0 2px 10px rgba(0, 0, 0, 0.07);
      border-radius: 8px;
      padding: 0;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition: max-height 0.25s ease, opacity 0.2s ease, padding 0.25s ease;
    }

    .nav-sections-pill.anchors-open .nav-anchors-popover {
      max-height: 600px;
      opacity: 1;
      pointer-events: auto;
      padding: 10px 12px;
    }

    .nav-anchors-popover .anchor-link {
      padding: 13px 0;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .nav-anchors-popover .anchor-link:last-child { border-bottom: none; }
  }
</style>

<script>
  // Scroll listener registered once to avoid accumulation across page loads
  let scrollListenerAdded = false;
  // AbortController to clean up init() listeners on each navigation
  let initController: AbortController | null = null;

  function smoothScrollTo(target: HTMLElement) {
    const html = document.documentElement;
    html.style.scrollSnapType = 'none';
    target.scrollIntoView({ behavior: 'smooth' });
    let fallback: ReturnType<typeof setTimeout>;
    const restore = () => { html.style.scrollSnapType = ''; clearTimeout(fallback); };
    html.addEventListener('scrollend', restore, { once: true });
    fallback = setTimeout(restore, 1000);
  }

  function init() {
    initController?.abort();
    initController = new AbortController();
    const { signal } = initController;

    const nav = document.getElementById('site-nav');
    if (!nav) return;

    const navLinks = nav.querySelectorAll<HTMLAnchorElement>('.nav-link');

    if (!scrollListenerAdded) {
      scrollListenerAdded = true;
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 0);
        if (window.scrollY === 0) {
          nav.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
            link.classList.toggle('active', link.getAttribute('href') === '#about');
          });
        }
      }, { passive: true });
    }

    const onHomePage = window.location.pathname === '/';

    if (navLinks.length > 0) {
      // Rewrite main nav hrefs for cross-page navigation.
      navLinks.forEach(link => {
        const href = link.getAttribute('href') || '';
        const hash = href.startsWith('/') ? href.slice(1) : href;
        if (hash.startsWith('#')) {
          link.href = onHomePage ? hash : '/' + hash;
        }
      });

      navLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          const href = link.getAttribute('href');
          if (!href || !href.startsWith('#')) return;
          const target = document.getElementById(href.slice(1));
          if (!target) return;
          e.preventDefault();
          history.pushState(null, '', href);
          smoothScrollTo(target);
        }, { signal });
      });

      const sections = document.querySelectorAll<HTMLElement>('#about, #case-studies, #contact');
      if (sections.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                navLinks.forEach((link) => {
                  link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
                });
              }
            });
          },
          { threshold: 0.5 }
        );
        sections.forEach((section) => observer.observe(section));
      }
    }

    // Mobile sections pill toggle
    const toggle = nav.querySelector<HTMLButtonElement>('.nav-anchors-toggle');
    const sectionsPill = nav.querySelector<HTMLElement>('.nav-sections-pill');
    if (toggle && sectionsPill) {
      const closePopover = () => {
        sectionsPill.classList.remove('anchors-open');
        toggle.setAttribute('aria-expanded', 'false');
      };

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = sectionsPill.classList.toggle('anchors-open');
        toggle.setAttribute('aria-expanded', String(open));
      }, { signal });

      // close when an anchor is tapped
      nav.querySelectorAll<HTMLAnchorElement>('.anchor-link').forEach(link => {
        link.addEventListener('click', closePopover, { signal });
      });

      // close when clicking anywhere outside the sections pill
      document.addEventListener('click', (e) => {
        if (!sectionsPill.contains(e.target as Node)) {
          closePopover();
        }
      }, { signal });
    }

    const anchorLinks = nav.querySelectorAll<HTMLAnchorElement>('.nav-anchors-popover .anchor-link, .nav-anchors .anchor-link');
    const uniqueAnchors = Array.from(new Set(Array.from(anchorLinks).map(l => l.getAttribute('href'))))
      .map(href => nav.querySelector<HTMLAnchorElement>(`.anchor-link[href="${href}"]`))
      .filter(Boolean) as HTMLAnchorElement[];

    if (uniqueAnchors.length > 0) {
      const ids = uniqueAnchors
        .map(l => l.getAttribute('href')?.slice(1))
        .filter(Boolean) as string[];
      const targets = document.querySelectorAll<HTMLElement>(ids.map(id => `#${id}`).join(', '));

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            nav.querySelectorAll<HTMLAnchorElement>('.anchor-link').forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`);
            });
          }
        });
      }, { threshold: 0.3 });

      targets.forEach(t => observer.observe(t));
    }
  }

  // Sync persisted nav state before each page swap
  let swapHandlerAdded = false;
  function setupSwapHandler() {
    if (swapHandlerAdded) return;
    swapHandlerAdded = true;

    document.addEventListener('astro:before-swap', (e) => {
      const nav = document.getElementById('site-nav');
      if (!nav) return;
      const newNav = (e as Event & { newDocument: Document }).newDocument.getElementById('site-nav');
      if (!newNav) return;

      // Sync active main link
      const newActiveHref = newNav.querySelector('.nav-link.active')?.getAttribute('href') ?? null;
      nav.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
        link.classList.toggle('active', link.getAttribute('href') === newActiveHref);
      });

      // Sync desktop inline anchor row
      const anchorsDiv = nav.querySelector<HTMLElement>('.nav-anchors');
      const newAnchorsDiv = newNav.querySelector('.nav-anchors');
      const newLinks = newAnchorsDiv ? Array.from(newAnchorsDiv.children) : [];

      if (newLinks.length > 0) {
        anchorsDiv?.replaceChildren(...newLinks.map(l => l.cloneNode(true) as Node));
        anchorsDiv?.offsetHeight; // force reflow
        nav.classList.add('has-anchors');
        anchorsDiv?.classList.add('visible');
      } else {
        anchorsDiv?.classList.remove('visible');
        nav.classList.remove('has-anchors');
        let done = false;
        const clear = () => { if (!done) { done = true; anchorsDiv?.replaceChildren(); } };
        anchorsDiv?.addEventListener('transitionend', clear, { once: true });
        setTimeout(clear, 350);
      }

      // Sync mobile popover anchor list
      const popoverDiv = nav.querySelector<HTMLElement>('.nav-anchors-popover');
      const newPopoverDiv = newNav.querySelector('.nav-anchors-popover');
      const newPopoverLinks = newPopoverDiv ? Array.from(newPopoverDiv.children) : [];
      if (newPopoverLinks.length > 0) {
        popoverDiv?.replaceChildren(...newPopoverLinks.map(l => l.cloneNode(true) as Node));
      } else {
        popoverDiv?.replaceChildren();
        // Also hide the sections pill if no anchors on new page
        const sectionsPill = nav.querySelector<HTMLElement>('.nav-sections-pill');
        sectionsPill?.classList.remove('anchors-open');
      }

      // Sync ← Back link
      const navBack = nav.querySelector<HTMLAnchorElement>('.nav-back');
      const newNavBack = newNav.querySelector<HTMLAnchorElement>('.nav-back');
      if (newNavBack && !navBack) {
        const anchorsDiv = nav.querySelector<HTMLElement>('.nav-anchors');
        anchorsDiv?.before(newNavBack.cloneNode(true));
      } else if (!newNavBack && navBack) {
        navBack.remove();
      }

      // Sync mobile sections pill
      const sectionsPillEl = nav.querySelector<HTMLElement>('.nav-sections-pill');
      const newSectionsPillEl = newNav.querySelector<HTMLElement>('.nav-sections-pill');
      if (newSectionsPillEl && !sectionsPillEl) {
        nav.appendChild(newSectionsPillEl.cloneNode(true));
      } else if (!newSectionsPillEl && sectionsPillEl) {
        sectionsPillEl.remove();
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    setupSwapHandler();
    init();

    // After a cross-page nav to e.g. /#about, scroll to the target section.
    const hash = window.location.hash;
    if (hash) {
      const target = document.getElementById(hash.slice(1));
      if (target) {
        requestAnimationFrame(() => smoothScrollTo(target));
      }
    }
  });
</script>
