<section id="about">
  <div class="content">
    <p class="greeting">Hello. I'm Marshall</p>
    <p class="intro">
      I'm a Staff Product Designer at <a href="https://dialpad.com" class="accent-link">Dialpad</a> focused on building intelligent product systems that scale.
    </p>
  </div>
</section>

<style>
  #about {
    height: 100vh;
    scroll-snap-align: start;
    overflow: hidden;
    position: relative;
  }

  .content {
    position: absolute;
    left: calc(8.33% + 15px);
    top: 50%;
    transform: translateY(-50%);
    max-width: 680px;
  }

  .greeting,
  .intro {
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 34px;
    line-height: 1.3;
    margin: 0 0 8px 0;
  }

  .greeting {
    opacity: 0.3;
  }

  .intro {
    opacity: 1;
  }

  .accent-link {
    color: #7c52ff;
    text-decoration: underline;
  }
</style>
