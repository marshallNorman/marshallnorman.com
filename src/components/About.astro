---
const BIO_PARAGRAPHS = [
  `Hi, I'm Marshall's virtual assistant. Marshall has spent over a decade designing complex product systems — AI platforms, design systems, enterprise SaaS — but the thread running through all of it has always been people. Real humans navigating real complexity. He believes the best design earns trust, and that belief shapes everything from the guardrails he builds into autonomous systems to how he shows up for the designers he mentors. His path has taken him from front-end development at Sparkbox to staff-level product design at Dialpad, where he led their first agentic AI platform — and what's carried across every stop is a conviction that as the systems we build become more powerful, our responsibility to keep them human becomes more important, not less.`,
];

const EXAMPLES = [
  "Where can I get your resume?",
  "What kind of work do you do?",
  "How do you approach design leadership?",
  "What's your background with AI products?",
  "How can I get in touch?",
  "What does your design process look like?",
];
---

<!-- Single snap section: headline left + chat right on desktop -->
<section id="about">
  <!-- Left column: headline -->
  <div class="left-col">
    <div class="content">
      <p class="greeting">Hello. I'm Marshall.</p>
      <p class="intro">
        I'm a Staff Product Designer at <a href="https://dialpad.com" class="accent-link">Dialpad</a> focused on building intelligent product systems that scale.
      </p>
      <p class="site-note">Welcome to my new site. I'm building it when I have time. New case study <a href="/case-studies/dialpad-ai-platform" class="accent-link">here</a>.</p>
      <button id="chat-open" class="chat-trigger" data-glass>
        <div class="cta-blurb">
          <p>With over 10 years of product design experience spanning across AI platform design, design systems, and human-centered product work, I bring both strategic vision and hands-on craft to every team I join.</p>
          <p>I have spent my career making complex things feel simple while bringing my peers along for the ride.</p>
        </div>
        <div class="cta-divider"></div>
        <div class="cta-bottom">
          <span>Learn a bit about me here.</span>
          <span class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          </span>
        </div>
      </button>
    </div>
  </div>

  <!-- Backdrop — mobile only, behind the modal -->
  <div id="chat-backdrop"></div>

  <!-- Right column: chat — always visible on desktop, bottom sheet on mobile -->
  <div class="right-col" id="conversation">
    <button id="chat-close" aria-label="Close chat" data-glass><span>✕</span></button>

    <!-- Desktop CTA (hidden on mobile) -->
    <div id="desktop-cta" class="desktop-cta">
      <button class="cta-card" data-glass>
        <div class="cta-blurb">
          <p>With over 10 years of product design experience spanning across AI platform design, design systems, and human-centered product work, I bring both strategic vision and hands-on craft to every team I join.</p>
          <p>I have spent my career making complex things feel simple while bringing my peers along for the ride.</p>
        </div>
        <div class="cta-divider"></div>
        <div class="cta-bottom">
          <span class="cta-text">Learn a bit about me here.</span>
          <span class="cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          </span>
        </div>
      </button>
    </div>

    <div class="chat-content" id="chat-content">
      <div class="top-spacer"></div>
      <div id="chat-messages"></div>
    </div>

    <div class="input-area">
      <div class="input-wrap" data-glass>
        <div id="chat-suggestions"></div>
        <div class="input-row">
          <textarea
            id="chat-input"
            rows="1"
            autocomplete="off"
            spellcheck="true"
            placeholder={`e.g. ${EXAMPLES[0]}`}
          ></textarea>
          <span id="chat-limit-msg" class="chat-limit-msg" hidden>Use the <a href="#contact">contact section</a> for any more questions</span>
          <button id="chat-send" aria-label="Send message">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>
        </div>
      </div>
      <p id="chat-hint" class="chat-hint">5 messages remaining</p>
    </div>
  </div>
</section>

<div id="bio-data" data-paragraphs={JSON.stringify(BIO_PARAGRAPHS)} hidden></div>

<style>
  /* ── Desktop: two-column snap section ── */
  #about {
    display: flex;
    align-items: stretch;
    gap: 64px;
    height: 100vh;
    overflow: hidden;
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
  }

  .left-col {
    flex: 1;
    display: flex;
    align-items: center;
    padding-left: calc(8.33% + 12px);
  }

  .content {
    max-width: 680px;
  }

  .greeting,
  .intro {
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 34px;
    line-height: 1.3;
    margin: 0 0 8px 0;
  }

  .greeting {
    opacity: 0.3;
  }

  .accent-link {
    color: #7c52ff;
    text-decoration: underline;
  }

  .site-note {
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    line-height: 1.5;
    opacity: 0.4;
    margin: 16px 0 24px 0;
  }

  /* Hidden on desktop */
  .chat-trigger { display: none; }
  #chat-close   { display: none; }

  /* ── Right column (chat) ── */
  .right-col {
    display: flex;
    flex-direction: column;
    width: 560px;
    flex-shrink: 0;
    height: 100vh;
    padding: 0 calc(8.33% / 2 + 12px) 16px 0;
  }

  /* ── Desktop CTA ── */
  .desktop-cta {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 0 12px;
    transition: opacity 0.2s ease;
  }

  @keyframes cta-slide-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes icon-pulse {
    0%   { transform: translate(-50%, -50%) scale(0.6); opacity: 0.5; }
    100% { transform: translate(-50%, -50%) scale(2.4); opacity: 0; }
  }

  .desktop-cta {
    animation: cta-slide-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.6s both;
  }

  .cta-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 24px;
    border-radius: 12px;
    width: 100%;
    cursor: pointer;
    text-align: left;
    background: transparent;
    color: inherit;
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 16px;
    line-height: 1.5;
  }

  .cta-blurb {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 20px;
  }

  .cta-blurb p {
    margin: 0;
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 15px;
    line-height: 1.65;
    opacity: 0.75;
  }

  .cta-divider {
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
    margin-bottom: 20px;
  }

  .cta-bottom {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .cta-text {
    flex: 1;
  }

  .cta-icon {
    flex-shrink: 0;
    opacity: 0.45;
    display: flex;
    align-items: center;
    position: relative;
  }

  .cta-icon::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(124, 82, 255, 0.35);
    transform: translate(-50%, -50%) scale(0.6);
    animation: icon-pulse 2.2s ease-out 1.6s infinite;
    pointer-events: none;
  }

  .chat-content {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    min-height: 0;
    scrollbar-width: none;
    padding: 0 12px;
  }

  /* Desktop hide/show is handled by a global style below — no scoped rules needed here */

  .chat-content::-webkit-scrollbar {
    display: none;
  }

  .top-spacer {
    flex: 1;
  }

  #chat-messages {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 16px;
  }

  :global(.msg-marshall) {
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 14px;
    line-height: 28px;
    color: #000;
    align-self: flex-start;
    padding-left: 10px;
    padding-right: 52px;
  }

  :global(.msg-marshall a) {
    color: #7c52ff;
    text-decoration: underline;
  }

  :global(.msg-user) {
    font-family: "IBM Plex Mono", "Courier New", monospace;
    font-size: 13px;
    line-height: 1.5;
    align-self: flex-end;
    background: #000;
    color: rgba(255, 255, 255, 0.9);
    border-radius: 18px 18px 4px 18px;
    padding: 8px 14px;
    max-width: 80%;
    margin-right: 10px;
  }

  :global(.typing-dots) {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    height: 28px;
  }

  :global(.typing-dots) span {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.3);
    animation: dot-bounce 1.2s infinite;
  }

  :global(.typing-dots) span:nth-child(2) { animation-delay: 0.2s; }
  :global(.typing-dots) span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dot-bounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
    40%           { transform: translateY(-4px); opacity: 1; }
  }

  .input-area {
    flex-shrink: 0;
    background: transparent;
    padding: 0 12px;
  }

  .chat-hint {
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px;
    color: rgba(0, 0, 0, 0.35);
    margin: 7px 10px 0;
    line-height: 1;
  }

  .chat-hint a {
    color: inherit;
    text-decoration: underline;
  }

  .chat-limit-msg {
    flex: 1;
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 14px;
    color: rgba(0, 0, 0, 0.5);
  }

  .chat-limit-msg a {
    color: inherit;
    text-decoration: underline;
  }

  #chat-backdrop {
    display: none;
  }

  .input-wrap {
    display: flex;
    flex-direction: column;
    min-height: 42px;
    padding: 7px 10px;
    border-radius: 16px;
  }

  .input-row {
    display: flex;
    align-items: flex-end;
    gap: 8px;
  }

  #chat-suggestions {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    padding-bottom: 0;
    margin-bottom: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, padding-bottom 0.35s ease, margin-bottom 0.35s ease;
  }

  #chat-suggestions.visible {
    max-height: 200px;
    opacity: 1;
    padding-bottom: 10px;
    margin-bottom: 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  :global(.suggestions-label) {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.3);
    margin-bottom: 4px;
  }

  :global(.suggestion-chip) {
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 14px;
    line-height: 22px;
    color: rgba(0, 0, 0, 0.4);
    background: none;
    border: none;
    padding: 3px 0;
    cursor: pointer;
    text-align: left;
    transition: color 0.15s;
  }

  :global(.suggestion-chip:hover) {
    color: #000;
  }

  :global(.msg-skeleton) {
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding: 4px 52px 4px 10px;
  }

  :global(.skel-line) {
    display: block;
    height: 11px;
    border-radius: 6px;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.06) 25%,
      rgba(0, 0, 0, 0.11) 50%,
      rgba(0, 0, 0, 0.06) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.4s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  #chat-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 14px;
    line-height: 22px;
    color: #000;
    outline: none;
    min-width: 0;
    resize: none;
    overflow-y: hidden;
    max-height: 120px;
    padding: 0;
    display: block;
  }

  #chat-input::placeholder {
    color: rgba(0, 0, 0, 0.4);
  }

  #chat-input:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  #chat-send {
    border: none;
    background: transparent;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.1s;
  }

  #chat-send:hover  { opacity: 0.6; }
  #chat-send:active { transform: scale(0.9); }

  #chat-send:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  /* ── Mid-size (tablets / small laptops) ── */
  @media (min-width: 769px) and (max-width: 1100px) {
    .left-col {
      padding-left: 32px;
    }

    .right-col {
      width: 400px;
      padding-right: 20px;
    }

    .greeting,
    .intro {
      font-size: 26px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    #about {
      display: block;
      height: 100vh;
      overflow: visible;
      background: var(--color-surface-primary);
    }

    .desktop-cta { display: none; }

    /* Vertically center the hero text */
    .left-col {
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 0 24px;
    }

    .content {
      max-width: 100%;
    }

    .greeting {
      font-size: 18px;
    }

    .intro {
      font-size: 28px;
    }

    /* White card button */
    .chat-trigger {
      display: flex;
      flex-direction: column;
      gap: 0;
      width: 100%;
      margin-top: 20px;
      padding: 20px;
      border-radius: 12px;
      font-family: "IBM Plex Serif", Georgia, serif;
      font-size: 16px;
      line-height: 1.4;
      color: #000;
      cursor: pointer;
      text-align: left;
      box-sizing: border-box;
      animation: cta-slide-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.6s both;
    }

    .chat-trigger .cta-blurb p {
      font-size: 14px;
    }

    .chat-trigger:hover { opacity: 0.85; }

    .trigger-arrow {
      flex-shrink: 0;
      font-size: 20px;
      line-height: 1;
    }

    #chat-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 39;
      background: rgba(0, 0, 0, 0.5);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    #chat-backdrop.open {
      opacity: 1;
      pointer-events: auto;
    }

    /* Full-screen modal: edge-to-edge, no gaps, no rounded corners */
    #conversation {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 40;
      background: var(--color-surface-primary);
      border-radius: 0;
      display: none;
      flex-direction: column;
      /* override desktop .right-col dimensions */
      width: auto;
      height: auto;
      padding: env(safe-area-inset-top, 0px) 0 0 0;
      overflow: hidden;
    }

    /* On mobile the chat body is always visible inside the modal */
    .chat-content,
    .input-area {
      display: flex;
      opacity: 1;
    }

    .input-area {
      display: block;
    }

    .chat-content {
      padding: 0 8px;
    }

    .input-area {
      padding: 0 8px calc(env(safe-area-inset-bottom, 0px) + 8px);
    }

    #conversation.open {
      display: flex;
    }

    /* Close button inside the sheet */
    #chat-close {
      position: absolute;
      top: 8px;
      right: 8px;
      border-radius: 10px;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      cursor: pointer;
      line-height: 1;
      z-index: 1;
    }

    /* Font sizes inside modal */
    .bio-text {
      font-size: 12px;
      line-height: 20px;
    }

    :global(.msg-marshall) {
      font-size: 12px;
      line-height: 20px;
    }

    :global(.msg-user) {
      font-size: 12px;
    }

    :global(body.chat-open #site-nav) {
      display: none;
    }
  }
</style>

<script>
  const EXAMPLES = [
    "Where can I get your resume?",
    "What kind of work do you do?",
    "How do you approach design leadership?",
    "What's your background with AI products?",
    "How can I get in touch?",
    "What does your design process look like?",
  ];

  const QUESTION_POOL = [
    "What's Marshall's design philosophy when it comes to AI products?",
    "How does Marshall approach leading a design team?",
    "Tell me about Marshall's work at Dialpad.",
    "What does Marshall's design process look like?",
    "How has Marshall's front-end background shaped how he designs?",
    "What kind of opportunities is Marshall looking for?",
    "How can I get in touch with Marshall?",
    "Where can I find Marshall's resume?",
    "What has Marshall worked on outside of Dialpad?",
  ];

  let BIO_PARAGRAPHS: string[] = [];
  try {
    BIO_PARAGRAPHS = JSON.parse(
      (document.getElementById('bio-data') as HTMLDivElement).dataset.paragraphs ?? '[]'
    );
  } catch (e) {
    console.error('About: failed to parse bio data', e);
  }

  const conversation  = document.getElementById('conversation')  as HTMLElement;
  const backdrop      = document.getElementById('chat-backdrop') as HTMLElement;
  const openBtn       = document.getElementById('chat-open')     as HTMLButtonElement;
  const closeBtn      = document.getElementById('chat-close')    as HTMLButtonElement;
  const input         = document.getElementById('chat-input')    as HTMLTextAreaElement;
  const sendBtn       = document.getElementById('chat-send')     as HTMLButtonElement;
  const chatContent   = document.getElementById('chat-content')  as HTMLDivElement;
  const messagesEl    = document.getElementById('chat-messages') as HTMLDivElement;

  const delay = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  function autoResize() {
    input.style.height = 'auto';
    const maxH = 120;
    input.style.height = Math.min(input.scrollHeight, maxH) + 'px';
    input.style.overflowY = input.scrollHeight > maxH ? 'auto' : 'hidden';
    scrollToBottom();
  }

  input.addEventListener('input', () => {
    if (input.value.length > 0) hideSuggestions();
    autoResize();
  });

  function scrollToBottom() {
    chatContent.scrollTop = chatContent.scrollHeight;
  }

  function createSkeleton(): HTMLElement {
    const el = document.createElement('div');
    el.className = 'msg-skeleton';
    [88, 76, 84, 70, 56].forEach(w => {
      const line = document.createElement('span');
      line.className = 'skel-line';
      line.style.width = w + '%';
      el.appendChild(line);
    });
    return el;
  }

  async function runChatIntro() {
    input.disabled   = true;
    sendBtn.disabled = true;

    // Show skeleton
    const skeletonEl = createSkeleton();
    messagesEl.appendChild(skeletonEl);
    scrollToBottom();
    await delay(700);

    // Fade skeleton out
    skeletonEl.style.transition = 'opacity 0.3s ease';
    skeletonEl.style.opacity = '0';
    await delay(320);
    skeletonEl.remove();

    // Render content invisible
    const allEls: HTMLElement[] = [];
    BIO_PARAGRAPHS.forEach(para => {
      const el = document.createElement('div');
      el.className = 'msg-marshall';
      el.textContent = para;
      el.style.opacity = '0';
      el.style.transition = 'opacity 0.5s ease';
      messagesEl.appendChild(el);
      allEls.push(el);
    });
    const welcome = document.createElement('div');
    welcome.className = 'msg-marshall';
    welcome.textContent = 'What would you like to ask me?';
    welcome.style.opacity = '0';
    welcome.style.transition = 'opacity 0.5s ease';
    messagesEl.appendChild(welcome);
    allEls.push(welcome);

    scrollToBottom();
    // Double rAF ensures layout is computed before transition fires
    requestAnimationFrame(() => requestAnimationFrame(() => {
      allEls.forEach(el => { el.style.opacity = '1'; });
    }));
    await delay(550);

    input.disabled   = false;
    sendBtn.disabled = false;
    showSuggestions();
  }

  const suggestionsEl = document.getElementById('chat-suggestions') as HTMLDivElement;

  function showSuggestions() {
    suggestionsEl.innerHTML = '';
    const label = document.createElement('span');
    label.className = 'suggestions-label';
    label.textContent = 'Example questions';
    suggestionsEl.appendChild(label);
    const picked = QUESTION_POOL
      .slice()
      .sort(() => Math.random() - 0.5)
      .slice(0, 3);
    picked.forEach(q => {
      const btn = document.createElement('button');
      btn.className = 'suggestion-chip';
      btn.textContent = q;
      btn.addEventListener('click', () => {
        input.value = q;
        input.focus();
        autoResize();
      });
      suggestionsEl.appendChild(btn);
    });
    suggestionsEl.classList.add('visible');
  }

  function hideSuggestions() {
    suggestionsEl.classList.remove('visible');
    suggestionsEl.innerHTML = '';
  }

  function collapseSuggestions() {
    suggestionsEl.classList.remove('visible');
    setTimeout(() => { suggestionsEl.innerHTML = ''; }, 380);
  }

  // ── Populate chat instantly (mobile) ──────────────────────
  function populateChatInstant() {
    if (messagesEl.children.length) return; // already populated
    BIO_PARAGRAPHS.forEach(para => {
      const el = document.createElement('div');
      el.className = 'msg-marshall';
      el.textContent = para;
      messagesEl.appendChild(el);
    });
    const welcome = document.createElement('div');
    welcome.className = 'msg-marshall';
    welcome.textContent = "What would you like to ask me?";
    messagesEl.appendChild(welcome);
    showSuggestions();
  }

  // ── Activate chat with typewriter (desktop) ───────────────
  let chatActivated = false;

  async function activateChat() {
    if (chatActivated) return;
    chatActivated = true;

    const ctaEl       = document.getElementById('desktop-cta')     as HTMLElement;
    const inputAreaEl = document.querySelector('.input-area') as HTMLElement;

    input.disabled   = true;
    sendBtn.disabled = true;

    // 1. Fade out CTA
    ctaEl.style.transition = 'opacity 0.2s ease';
    ctaEl.style.opacity    = '0';
    ctaEl.style.pointerEvents = 'none';
    await delay(220);
    ctaEl.style.display = 'none';

    // 2. Show chat structure at opacity 0
    chatContent.style.display = 'flex';
    inputAreaEl.style.display = 'block';

    // 3. Reflow → fade in
    chatContent.offsetHeight; // force reflow
    chatContent.style.opacity  = '1';
    inputAreaEl.style.opacity  = '1';

    await delay(350);
    runChatIntro();
  }

  // ── Click handlers ────────────────────────────────────────
  const ctaCard = document.querySelector('.cta-card') as HTMLButtonElement | null;
  const isMobile = () => window.innerWidth <= 768;

  if (ctaCard) {
    ctaCard.addEventListener('click', () => {
      if (!isMobile()) activateChat();
    });
  }

  // Mobile: open modal + animate greeting (same typewriter as desktop)
  openBtn.addEventListener('click', () => {
    conversation.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('chat-open');
    document.body.style.overflow = 'hidden';

    if (!chatActivated) {
      chatActivated = true;
      setTimeout(() => runChatIntro(), 200); // let modal finish opening
    } else {
      input.focus();
    }
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') closeModal();
  });

  function closeModal() {
    conversation.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('chat-open');
    document.body.style.overflow = '';
  }

  // ── Close mobile modal when a hash link is tapped ────────
  messagesEl.addEventListener('click', (e) => {
    const anchor = (e.target as Element).closest('a');
    if (!anchor) return;
    const href = anchor.getAttribute('href') ?? '';
    if (href.startsWith('#') && window.innerWidth <= 768) {
      closeModal();
    }
  });

  // ── Placeholder cycling ───────────────────────────────────
  let exampleIdx = 0;
  setInterval(() => {
    exampleIdx = (exampleIdx + 1) % EXAMPLES.length;
    input.placeholder = `e.g. ${EXAMPLES[exampleIdx]}`;
  }, 6000);

  // ── Chat API ──────────────────────────────────────────────
  const MAX_MESSAGES = 5;
  let userMessageCount = 0;
  const hintEl = document.getElementById('chat-hint') as HTMLParagraphElement;
  const limitMsgEl = document.getElementById('chat-limit-msg') as HTMLSpanElement;

  function updateHint() {
    const remaining = MAX_MESSAGES - userMessageCount;
    if (remaining <= 0) {
      input.hidden = true;
      sendBtn.style.display = 'none';
      limitMsgEl.hidden = false;
      hintEl.hidden = true;
    } else {
      hintEl.textContent = `${remaining} message${remaining === 1 ? '' : 's'} remaining`;
    }
  }

  const conversationHistory: { role: 'user' | 'assistant'; content: string }[] = [];

  let beaconSent = false;

  function sendBeacon() {
    if (beaconSent || conversationHistory.length === 0) return;
    beaconSent = true;
    const blob = new Blob([JSON.stringify(conversationHistory)], { type: 'application/json' });
    navigator.sendBeacon('/api/log-chat', blob);
  }

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') sendBeacon();
  });
  window.addEventListener('pagehide', sendBeacon);

  function appendUserBubble(text: string) {
    const el = document.createElement('div');
    el.className = 'msg-user';
    el.textContent = text;
    messagesEl.appendChild(el);
    scrollToBottom();
  }

  function appendMarshallBubble(): HTMLDivElement {
    const el = document.createElement('div');
    el.className = 'msg-marshall';
    el.innerHTML = '<span class="typing-dots"><span></span><span></span><span></span></span>';
    messagesEl.appendChild(el);
    scrollToBottom();
    return el;
  }

  async function sendMessage(text: string) {
    if (!text.trim() || userMessageCount >= MAX_MESSAGES) return;

    collapseSuggestions();
    input.value = '';
    input.style.height = 'auto';
    input.style.overflowY = 'hidden';
    input.disabled = true;
    sendBtn.disabled = true;

    userMessageCount++;
    appendUserBubble(text);
    conversationHistory.push({ role: 'user', content: text });

    const bubble = appendMarshallBubble();
    let responseText = '';

    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conversationHistory }),
      });

      bubble.innerHTML = '';

      if (!response.ok) {
        const data = await response.json().catch(() => ({}));
        bubble.textContent = data.error === 'quota'
          ? "Marshall isn't rich and this thing costs money. If you have more questions email him at marshalldeannorman@gmail.com"
          : "Sorry, something went wrong. Try refreshing or reach out directly in the Contact section.";
      } else {
        const reader = response.body!.getReader();
        const decoder = new TextDecoder();
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          responseText += decoder.decode(value, { stream: true });
          bubble.textContent = responseText;
          scrollToBottom();
        }

        const DELIMITER = '---CONTACT_MSG---';
        const delimIdx = responseText.indexOf(DELIMITER);
        let visibleText = responseText;
        if (delimIdx !== -1) {
          visibleText = responseText.slice(0, delimIdx).trimEnd();
          let contactMsg = responseText.slice(delimIdx + DELIMITER.length).trim();
          // Strip any trailing delimiter the model may have hallucinated
          const trailingDelim = contactMsg.indexOf(DELIMITER);
          if (trailingDelim !== -1) contactMsg = contactMsg.slice(0, trailingDelim).trim();
          if (contactMsg) sessionStorage.setItem('contactPrefill', contactMsg);
        }

        const linkedHtml = visibleText
          .replace(/\*\*(.+?)\*\*/gs, '<strong>$1</strong>')
          .replace(/\*(.+?)\*/gs, '<em>$1</em>')
          .replace(/_(.+?)_/gs, '<em>$1</em>')
          .replace(/\[([^\]]+)\]\(((?:https?:\/\/|#|\/)[^)]+)\)/g, '<a href="$2">$1</a>');
        bubble.innerHTML = linkedHtml;

        conversationHistory.push({ role: 'assistant', content: visibleText });
      }
    } catch {
      bubble.textContent = "Sorry, something went wrong. Try refreshing or reach out directly in the Contact section.";
    }

    updateHint();
    if (userMessageCount < MAX_MESSAGES) {
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  sendBtn.addEventListener('click', () => {
    const text = input.value.trim();
    if (text) sendMessage(text);
  });

  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      const text = input.value.trim();
      if (text) sendMessage(text);
    }
  });
</script>
