---
const projects = [
  {
    name: "Designing Dialpad's Agentic AI Platform",
    role: "Staff Product Designer",
    year: "2024-2026",
    description: "Defined a unified agent model that moved beyond reactive feature shipping — aligning product, engineering, and leadership around a coherent AI vision.",
    href: "/case-studies/dialpad-ai-platform",
    image: "/images/case-study-dialpad.svg",
    logo: "/images/dialpad-wordmark.svg",
    comingSoon: false,
  },
  {
    name: "Rebuilding Dialtone",
    role: "Lead Designer",
    year: "2022-2023",
    description: "Complete overhaul of the Dialtone design system to elevate Dialpad's visual language. Addressed everything from base styles to interaction paradigms.",
    href: "#",
    image: "/images/case-study-dialtone.svg",
    comingSoon: true,
  },
  {
    name: "Scaling MarketMuse's Design Practice",
    role: "Senior Product Designer",
    year: "2019-2020",
    description: "As the sole designer at a fast moving company, I worked to develop a design system while also building the product.",
    href: "#",
    image: "/images/case-study-marketmuse.svg",
    comingSoon: true,
  },
];
---
<section id="case-studies">
  <h2 class="section-heading">Case Studies</h2>
  <div class="grid">
    {projects.map((project, i) => (
      <a href={project.comingSoon ? undefined : project.href} class="card">
        <div
          class="card-image"
          style={project.image ? `background-image: url('${project.image}'); background-size: cover; background-position: center;` : undefined}
        />
        {project.logo && (
          <img class="card-logo" src={project.logo} alt={project.name} />
        )}
        <div class="card-overlay">
          <p class="card-name">
            {project.name}
            {project.comingSoon && <span class="badge">Coming soon</span>}
          </p>
          <p class="card-meta">{project.role} · {project.year}</p>
          <p class="card-desc">{project.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  /* ── Base (desktop) ── */
  #case-studies {
    height: 100vh;
    scroll-snap-align: start;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding-top: 40px;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.4;
    margin: 0;
    padding: 20px 20px 0;
  }

  .section-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(0, 0, 0, 0.2);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 16px;
    flex: 1;
    padding: 20px;
    box-sizing: border-box;
    min-height: 0;
  }

  .card:first-child {
    grid-row: span 2;
  }

  .card {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border-radius: 24px;
  }

  .card-image {
    width: 100%;
    height: 100%;
    background-color: #f0f0f0;
    transition: transform 0.3s ease;
    border-radius: 24px;
  }

  .card:hover .card-image {
    transform: scale(1.02);
  }

  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    color: #333333;
  }

  .card-name {
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 20px;
    margin: 0 0 4px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .badge {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(80,70,60,0.6);
    border: 1px solid rgba(80,70,60,0.25);
    border-radius: 4px;
    padding: 2px 7px;
    white-space: nowrap;
  }

  .card-meta {
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    opacity: 0.75;
    margin: 0 0 8px 0;
  }

  .card-desc {
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px;
    margin: 0;
    line-height: 1.5;
  }

  .card-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(180px, 35%, 300px);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Mobile — must come last so it overrides base rules above ── */
  @media (max-width: 768px) {
    #case-studies {
      height: auto;
      min-height: 100vh;
      overflow: visible;
      padding-top: 0;
    }

    .grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .card:first-child {
      grid-row: span 1;
    }

    /* Tall enough for image + overlay text to both be fully visible */
    .card {
      min-height: 260px;
    }

    .card-logo {
      display: none;
    }

    .card-image {
      height: 100%;
      position: absolute;
      inset: 0;
    }
  }
</style>
