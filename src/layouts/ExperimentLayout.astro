---
import Layout from './Layout.astro';
const { title } = Astro.props;
---
<Layout>
  <div class="exp-page">
    <header class="exp-header">
      <a href="/" class="exp-back">← Back</a>
      <span class="exp-title-label">{title}</span>
    </header>
    <main class="exp-canvas-area">
      <slot />
    </main>
  </div>
</Layout>

<style>
  .exp-page {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: #f9f9f9;
  }

  .exp-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    padding: 16px 24px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    background: #f9f9f9;
    z-index: 10;
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    opacity: 0.5;
  }

  .exp-back {
    color: inherit;
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .exp-back:hover {
    opacity: 1;
  }

  .exp-canvas-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
</style>
